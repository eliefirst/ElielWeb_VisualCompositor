<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceContainer name="product.info.media">
            <block class="Magento\Catalog\Block\Product\View"
                   name="product.visual.compositor"
                   template="ElielWeb_VisualCompositor::product/compositor.phtml"
                   after="-">
                <arguments>
                    <argument name="compositor_view_model" xsi:type="object">
                        ElielWeb\VisualCompositor\ViewModel\ProductCompositor
                    </argument>
                </arguments>
            </block>
        </referenceContainer>
    </body>
</page>
