<?php
$product             = $block->getData('product') ?? $block->getProduct();
$compositorViewModel = $block->getData('compositor_view_model');

if (!$product || !$compositorViewModel) { return; }
if (!($product instanceof \Magento\Catalog\Api\Data\ProductInterface)) { return; }
if (!$compositorViewModel->isEnabled($product)) { return; }

$configJson = $compositorViewModel->getConfigJson($product);
if ($configJson === '{}') { return; }
?>
<script>
(function() {
    function initVisualCompositor(config) {
        if (!config || !config.enabled) return;
        const images  = {};
        const current = {};
        let canvas = null, ctx = null, imgEl = null, observer = null;

        function loadImage(url) {
            if (images[url]) return Promise.resolve(images[url]);
            return new Promise((resolve, reject) => {
                const img = new Image();
                img.crossOrigin = 'anonymous';
                img.onload  = () => { images[url] = img; resolve(img); };
                img.onerror = () => reject(new Error('Failed: ' + url));
                img.src = url;
            });
        }

        function fitCanvas() {
            if (!imgEl || !canvas) return;
            const w = imgEl.offsetWidth;
            const h = imgEl.offsetHeight;
            if (!w || !h) return;
            canvas.width = w; canvas.height = h;
            canvas.style.width = w + 'px'; canvas.style.height = h + 'px';
        }

        function render() {
            if (!ctx || !canvas || !canvas.width) return;
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            [...(config.layers || [])].sort((a, b) => (a.sort_order||0)-(b.sort_order||0)).forEach(layer => {
                const url = current[layer.code];
                if (url && images[url]) { try { ctx.drawImage(images[url], 0, 0, canvas.width, canvas.height); } catch(e){} }
            });
        }

        function mount() {
            const galleryMain = document.getElementById('gallery-main');
            if (!galleryMain) return;
            imgEl = galleryMain.querySelector('img');
            if (!imgEl) return;
            const wrapper = imgEl.parentElement;
            wrapper.style.position = 'relative';
            canvas = document.createElement('canvas');
            canvas.style.cssText = 'position:absolute;top:0;left:0;pointer-events:none;z-index:10;';
            wrapper.appendChild(canvas);
            ctx = canvas.getContext('2d');
            fitCanvas();
            observer = new ResizeObserver(() => { fitCanvas(); render(); });
            observer.observe(imgEl);
            if (!imgEl.complete) imgEl.addEventListener('load', fitCanvas);
        }

        window.addEventListener('option-selected', function(e) {
            const { optionId, valueId } = e.detail || {};
            const layer = (config.layers || []).find(l => l.option_code == optionId);
            if (!layer) return;
            const url = layer.mappings[valueId] || layer.mappings[String(valueId)];
            if (!url) return;
            loadImage(url).then(() => { current[layer.code] = url; render(); });
        });

        window.addEventListener('compositor-gold-selected', function(e) {
            const { goldText } = e.detail || {};
            (config.layers || []).filter(l => l.option_code === 'gold_color').forEach(layer => {
                const url = layer.mappings[goldText];
                if (!url) return;
                loadImage(url).then(() => { current[layer.code] = url; render(); });
            });
        });

        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', () => setTimeout(mount, 500));
        } else {
            setTimeout(mount, 500);
        }
    }
    initVisualCompositor(<?= /* @noEscape */ $configJson ?>);
})();
</script>
